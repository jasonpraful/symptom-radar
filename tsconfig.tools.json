{
  // Typecheck for Node-side tooling: the vitest tests and the D1/node:sqlite test
  // double. Uses Node types instead of (only) the Workers runtime types.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node", "@cloudflare/workers-types"],
    "noEmit": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["test/**/*.ts", "src/**/*.ts"]
}

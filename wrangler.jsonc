{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "symptom-radar",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-09",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "uh.jasonpraful.co.uk",
      "custom_domain": true
    }
  ],
  // ─── Cron Triggers ──────────────────────────────────────────────────────────
  // Runs the daily fetch → store → assess → notify pipeline.
  // Default: 12:00 UTC daily (matches the original Python cron example `0 12 * * *`).
  "triggers": {
    "crons": ["0 12 * * *"]
  },
  // ─── D1 Database ────────────────────────────────────────────────────────────
  // Replaces the local SQLite `ultrahuman.db`.
  //
  // One-click "Deploy to Cloudflare" button: the binding + database_name below are
  // the defaults the deploy flow needs. Cloudflare auto-provisions a fresh D1 and
  // writes the real `database_id` back into this JSONC file before running the
  // `deploy` script (id write-back works for JSON/JSONC, not TOML), which applies
  // migrations against the `DB` binding.
  //
  // Manual setup instead: `wrangler d1 create symptom_radar` and paste the returned
  // database_id below.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "symptom_radar",
      "database_id": "cbf5cdb5-f10b-4e33-ad20-62bd5989cc22",
      "migrations_dir": "migrations"
    }
  ],
  // ─── Non-secret configuration ───────────────────────────────────────────────
  // Secrets (ULTRAHUMAN_TOKEN, WEBHOOK_URL, ADMIN_TOKEN, DASHBOARD_TOKEN) are set
  // via `wrangler secret put <NAME>` — never commit them here.
  "vars": {
    // "slack" | "discord" | "generic" | "auto" (auto-detect from WEBHOOK_URL host)
    "WEBHOOK_FORMAT": "auto",
    // Notify on these strain levels (comma-separated): 0=none,1=minor,2=major.
    // Default "1,2" => only notify when something is worth watching.
    "NOTIFY_ON_LEVELS": "1,2",
    // Backfill window used by the /api/backfill admin endpoint and first run.
    "BACKFILL_DAYS": "35"
  }
}
